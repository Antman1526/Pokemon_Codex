; Engine configuration file.
; Internal source uses generic monster-taming terms for long-term flexibility.

config_version=5

[application]

config/name="POKEMON NEXUS RED"
config/description="A native PC/Mac monster-taming RPG with classic FireRed-style roots and upgraded HD pixel presentation."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/mode=0
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

