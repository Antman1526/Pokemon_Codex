{
  "schema_version": 1,
  "seed_type": "psdk_rival_worldlink_registry",
  "source_import_id": "rival_worldlink_registry",
  "source_path": "data_design/rivals.yaml",
  "extra_source_paths": [
    "data_design/worldlink_notifications.yaml",
    "data_design/worldlink_schema.yaml",
    "data_design/rival_progression_kanto.yaml",
    "native/nexus-red/content/worldlink/opening_feed.json"
  ],
  "required_rival_count": 10,
  "starting_rivals": [
    "blue",
    "ava",
    "dax"
  ],
  "signature_rival": "blue",
  "preserve_rules": [
    "ten_rivals_travel_the_same_world_path",
    "blue_ava_dax_begin_with_antman_in_kanto",
    "worldlink_shows_rival_badges_captures_battles_losses_and_region_entries",
    "worldlink_pauses_during_caves_dungeons_hideouts_and_boss_events",
    "worldlink_digest_displays_after_leaving_paused_areas",
    "rival_notifications_respect_major_only_default"
  ],
  "worldlink_settings": {
    "unlock_timing": "after_blue_lab_battle",
    "default_notification_mode": "major_only",
    "recent_message_capacity": 32,
    "notification_modes": {
      "all": {
        "description": "Show major and minor updates."
      },
      "major_only": {
        "description": "Default. Show major rival/world events and store minor updates."
      },
      "rivals_only": {
        "description": "Show rival progress without broader world alerts."
      },
      "silent": {
        "description": "Store updates silently."
      }
    },
    "delivery_rules": {
      "immediate_safe_pop": [
        "rival_badge",
        "rival_region_entry",
        "villain_alert",
        "legendary_anomaly",
        "companion_request",
        "story_unlock"
      ],
      "batch_until_safe": [
        "rival_capture_common",
        "rival_minor_movement",
        "flavor_note",
        "swarm_hint",
        "daycare_update"
      ],
      "never_interrupt": [
        "battle",
        "gym_battle",
        "cutscene",
        "boss_event",
        "evolution",
        "starter_selection"
      ],
      "pause_and_digest": [
        "cave",
        "villain_hideout",
        "deep_forest",
        "ruins",
        "tower",
        "story_dungeon"
      ]
    },
    "digest": {
      "title": "While You Were Away",
      "trigger": "leaving_paused_area_for_safe_area",
      "max_items_mvp": 3,
      "max_items_target": 5,
      "priority_order": [
        "villain_alert",
        "rival_badge",
        "companion_request",
        "legendary_anomaly",
        "rival_region_entry",
        "rival_capture_common",
        "flavor_note"
      ]
    }
  },
  "required_notification_categories": {
    "rival_badge": {
      "priority": "major",
      "delivery": "immediate",
      "templates": [
        "{rival} defeated {leader} and earned the {badge} Badge.",
        "{rival} cleared {challenge}. Your World Circuit ranking changed."
      ]
    },
    "rival_capture": {
      "priority": "minor",
      "delivery": "batch_on_town_entry",
      "templates": [
        "{rival} caught {species} near {location}.",
        "{rival} added {species} to their team after training around {location}."
      ]
    },
    "rival_rare_capture": {
      "priority": "major",
      "delivery": "town_entry_or_immediate",
      "templates": [
        "{rival} reported a rare {species} sighting near {location}.",
        "{rival} caught a rare {species}. Check the Pokedex habitat notes."
      ]
    },
    "rival_loss": {
      "priority": "flavor",
      "delivery": "batch_on_town_entry",
      "templates": [
        "{rival} lost to {opponent} and is training near {location}.",
        "{rival} retreated from {dungeon}. They marked a safer route for you."
      ]
    },
    "rival_request": {
      "priority": "major",
      "delivery": "immediate",
      "templates": [
        "{rival} wants a rematch in {location}.",
        "{rival} requested backup for a tag battle near {location}."
      ]
    },
    "rival_region_entry": {
      "priority": "major",
      "delivery": "immediate",
      "templates": [
        "{rival} has entered {region}.",
        "{rival} checked in from {hub}. Their next target is {objective}."
      ]
    },
    "villain_alert": {
      "priority": "major",
      "delivery": "immediate",
      "templates": [
        "WorldLink Alert: {team} activity reported near {location}.",
        "{authority} issued a warning about {team} movement around {location}."
      ]
    },
    "legendary_anomaly": {
      "priority": "major",
      "delivery": "immediate",
      "templates": [
        "Anomaly detected: {legendary_signal} energy spiked near {location}.",
        "Professor Oak flagged unusual readings from {location}."
      ]
    }
  },
