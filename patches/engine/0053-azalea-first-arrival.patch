diff --git a/data/maps/AzaleaTown_Frlg/scripts.inc b/data/maps/AzaleaTown_Frlg/scripts.inc
new file mode 100644
index 0000000000..b0cce1197c
--- /dev/null
+++ b/data/maps/AzaleaTown_Frlg/scripts.inc
@@ -0,0 +1,103 @@
+AzaleaTown_Frlg_MapScripts::
+	map_script MAP_SCRIPT_ON_TRANSITION, AzaleaTown_Frlg_OnTransition
+	.byte 0
+
+AzaleaTown_Frlg_OnTransition:
+	setflag FLAG_AZALEA_FIRST_ARRIVAL_REACHED
+	end
+
+AzaleaTown_Frlg_EventScript_LyraTownEdge::
+	msgbox AzaleaTown_Frlg_Text_LyraTownEdge, MSGBOX_NPC
+	end
+
+AzaleaTown_Frlg_EventScript_RedTownWatch::
+	msgbox AzaleaTown_Frlg_Text_RedTownWatch, MSGBOX_NPC
+	end
+
+AzaleaTown_Frlg_EventScript_KurtWarning::
+	setflag FLAG_AZALEA_KURT_WARNING_REACHED
+	msgbox AzaleaTown_Frlg_Text_KurtWarning, MSGBOX_NPC
+	end
+
+AzaleaTown_Frlg_EventScript_RocketWellGuard::
+	msgbox AzaleaTown_Frlg_Text_RocketWellGuard, MSGBOX_NPC
+	end
+
+AzaleaTown_Frlg_EventScript_GoldDustTailMarket::
+	msgbox AzaleaTown_Frlg_Text_GoldDustTailMarket, MSGBOX_NPC
+	end
+
+AzaleaTown_Frlg_EventScript_BugsyAide::
+	msgbox AzaleaTown_Frlg_Text_BugsyAide, MSGBOX_NPC
+	end
+
+AzaleaTown_Frlg_EventScript_SilverTrace::
+	msgbox AzaleaTown_Frlg_Text_SilverTrace, MSGBOX_NPC
+	end
+
+AzaleaTown_Frlg_EventScript_SlowpokeWellLock::
+	setflag FLAG_AZALEA_SLOWPOKE_WELL_GATE_CHECKED
+	msgbox AzaleaTown_Frlg_Text_SlowpokeWellLock, MSGBOX_SIGN
+	end
+
+AzaleaTown_Frlg_EventScript_TownSign::
+	msgbox AzaleaTown_Frlg_Text_TownSign, MSGBOX_SIGN
+	end
+
+AzaleaTown_Frlg_Text_LyraTownEdge::
+	.string "LYRA: Azalea is quiet in\n"
+	.string "the wrong way.\p"
+	.string "People are staying indoors,\n"
+	.string "but nobody is confused about\n"
+	.string "where the problem is.$"
+
+AzaleaTown_Frlg_Text_RedTownWatch::
+	.string "RED: I will watch the cave\n"
+	.string "road behind us.\p"
+	.string "You talk to Kurt. If Rocket\n"
+	.string "pushes from the Well, I will\n"
+	.string "keep the exit clean.$"
+
+AzaleaTown_Frlg_Text_KurtWarning::
+	.string "KURT: Slowpoke are not\n"
+	.string "inventory.\p"
+	.string "Apricorn craft is for helping\n"
+	.string "Pokemon, not polishing greed.\p"
+	.string "Clear the Well, then we talk.$"
+
+AzaleaTown_Frlg_Text_RocketWellGuard::
+	.string "ROCKET: The well is closed.\p"
+	.string "Official safety inspection.\n"
+	.string "Unofficially, walk away.$"
+
+AzaleaTown_Frlg_Text_GoldDustTailMarket::
+	.string "GOLD DUST: A market is only\n"
+	.string "ugly until paperwork arrives.\p"
+	.string "Slowpoke tails, route access,\n"
+	.string "Gym delays--everything can be\n"
+	.string "priced if people are scared.$"
+
+AzaleaTown_Frlg_Text_BugsyAide::
+	.string "BUGSY AIDE: Gym challenge\n"
+	.string "delayed by town emergency.\p"
+	.string "Bugsy is studying how Rocket\n"
+	.string "moves like a swarm around\n"
+	.string "Slowpoke Well.$"
+
+AzaleaTown_Frlg_Text_SilverTrace::
+	.string "SILVER TRACE: Well side.\p"
+	.string "Still no battle.\p"
+	.string "He is watching how you handle\n"
+	.string "people who steal strength.$"
+
+AzaleaTown_Frlg_Text_SlowpokeWellLock::
+	.string "WorldLink: Slowpoke Well next.\p"
+	.string "Kurt is moving. Rocket is dug\n"
+	.string "in. Gold Dust is waiting to\n"
+	.string "profit from whoever wins.\p"
+	.string "Hoenn remains locked.$"
+
+AzaleaTown_Frlg_Text_TownSign::
+	.string "AZALEA TOWN\p"
+	.string "Apricorn craft, quiet wells,\n"
+	.string "and promises older than roads.$"
