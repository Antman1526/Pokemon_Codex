diff --git a/data/maps/Route32_Frlg/scripts.inc b/data/maps/Route32_Frlg/scripts.inc
new file mode 100644
index 0000000000..4fe56a82a0
--- /dev/null
+++ b/data/maps/Route32_Frlg/scripts.inc
@@ -0,0 +1,81 @@
+Route32_Frlg_MapScripts::
+	map_script MAP_SCRIPT_ON_TRANSITION, Route32_Frlg_OnTransition
+	.byte 0
+
+Route32_Frlg_OnTransition:
+	setflag FLAG_ROUTE32_FIRST_STEPS_REACHED
+	end
+
+Route32_Frlg_EventScript_LyraRoadGuide::
+	msgbox Route32_Frlg_Text_LyraRoadGuide, MSGBOX_NPC
+	end
+
+Route32_Frlg_EventScript_RedVioletBackup::
+	msgbox Route32_Frlg_Text_RedVioletBackup, MSGBOX_NPC
+	end
+
+Route32_Frlg_EventScript_FieldChecklist::
+	setflag FLAG_ROUTE32_FIELD_CHECKLIST_REVIEWED
+	msgbox Route32_Frlg_Text_FieldChecklist, MSGBOX_NPC
+	end
+
+Route32_Frlg_EventScript_SilverTrace::
+	msgbox Route32_Frlg_Text_SilverTrace, MSGBOX_NPC
+	end
+
+Route32_Frlg_EventScript_GoldDustToll::
+	msgbox Route32_Frlg_Text_GoldDustToll, MSGBOX_NPC
+	end
+
+Route32_Frlg_EventScript_RocketUnionCave::
+	msgbox Route32_Frlg_Text_RocketUnionCave, MSGBOX_NPC
+	end
+
+Route32_Frlg_EventScript_RouteSign::
+	msgbox Route32_Frlg_Text_RouteSign, MSGBOX_SIGN
+	end
+
+Route32_Frlg_Text_LyraRoadGuide::
+	.string "LYRA: Route 32 opens wide.\p"
+	.string "After Violet, Johto stops feeling\n"
+	.string "like one town helping another.\p"
+	.string "Now the road starts choosing who\n"
+	.string "is patient enough to notice it.$"
+
+Route32_Frlg_Text_RedVioletBackup::
+	.string "RED: I am staying in Violet.\p"
+	.string "Lyra knows this road better than\n"
+	.string "I do, and you should hear her.\p"
+	.string "If the wind changes, call me.$"
+
+Route32_Frlg_Text_FieldChecklist::
+	.string "FIELD CHECKLIST: Route 32.\p"
+	.string "Objective: reach Union Cave.\p"
+	.string "Habitat hints: MAREEP in open grass,\n"
+	.string "WOOPER near water at night.\p"
+	.string "TOGEPI rumors still point back\n"
+	.string "to egg-route research.$"
+
+Route32_Frlg_Text_SilverTrace::
+	.string "SILVER TRACE: No battle.\p"
+	.string "WorldLink caught movement toward\n"
+	.string "Union Cave, then nothing.\p"
+	.string "Silence from him feels deliberate.$"
+
+Route32_Frlg_Text_GoldDustToll::
+	.string "GOLD DUST TOLL: A clean route\n"
+	.string "needs clean ownership.\p"
+	.string "Public roads are old promises.\n"
+	.string "Old promises can be purchased.$"
+
+Route32_Frlg_Text_RocketUnionCave::
+	.string "ROCKET REMNANT: Union Cave is\n"
+	.string "not yours to map.\p"
+	.string "Bosses change. Routes stay useful.\p"
+	.string "WorldLink: Union Cave next.\n"
+	.string "Hoenn remains locked.$"
+
+Route32_Frlg_Text_RouteSign::
+	.string "ROUTE 32\p"
+	.string "Violet City - Union Cave\p"
+	.string "Field Checklist active.$"
