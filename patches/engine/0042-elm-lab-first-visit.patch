diff --git a/data/maps/NewBarkTown_ElmLab_Frlg/scripts.inc b/data/maps/NewBarkTown_ElmLab_Frlg/scripts.inc
new file mode 100644
index 0000000000..5fd4995381
--- /dev/null
+++ b/data/maps/NewBarkTown_ElmLab_Frlg/scripts.inc
@@ -0,0 +1,59 @@
+NewBarkTown_ElmLab_Frlg_MapScripts::
+	map_script MAP_SCRIPT_ON_TRANSITION, NewBarkTown_ElmLab_Frlg_OnTransition
+	.byte 0
+
+NewBarkTown_ElmLab_Frlg_OnTransition:
+	setflag FLAG_ELM_LAB_FIRST_VISIT_REACHED
+	end
+
+NewBarkTown_ElmLab_Frlg_EventScript_ElmFirstVisit::
+	msgbox NewBarkTown_ElmLab_Frlg_Text_ElmFirstVisit, MSGBOX_NPC
+	end
+
+NewBarkTown_ElmLab_Frlg_EventScript_RedLabSupport::
+	msgbox NewBarkTown_ElmLab_Frlg_Text_RedLabSupport, MSGBOX_NPC
+	end
+
+NewBarkTown_ElmLab_Frlg_EventScript_LyraLabGuide::
+	msgbox NewBarkTown_ElmLab_Frlg_Text_LyraLabGuide, MSGBOX_NPC
+	end
+
+NewBarkTown_ElmLab_Frlg_EventScript_Aide::
+	msgbox NewBarkTown_ElmLab_Frlg_Text_Aide, MSGBOX_NPC
+	end
+
+NewBarkTown_ElmLab_Frlg_Text_ElmFirstVisit::
+	.string "ELM: Welcome to my lab, Antman.\p"
+	.string "Oak sent your KANTO record, but\n"
+	.string "Johto is not just another badge list.\p"
+	.string "Pokemon here react to hour, friendship,\n"
+	.string "habitat, and old stories.\p"
+	.string "Route 29 is the next required road.\n"
+	.string "Watch the grass, not just trainers.\p"
+	.string "Silver's signal crossed Route 29\n"
+	.string "before we could identify him.\p"
+	.string "Hoenn remains locked until Johto's\n"
+	.string "own crisis is understood.$"
+
+NewBarkTown_ElmLab_Frlg_Text_RedLabSupport::
+	.string "RED: I will walk the first stretch\n"
+	.string "of Route 29 with you.\p"
+	.string "Not to lead you.\n"
+	.string "To make sure Johto gets your pace.\p"
+	.string "If Silver is watching the road, we\n"
+	.string "will notice him together.$"
+
+NewBarkTown_ElmLab_Frlg_Text_LyraLabGuide::
+	.string "LYRA: I know the Cherrygrove guide.\p"
+	.string "He looks harmless, but he notices\n"
+	.string "everything that enters town.\p"
+	.string "Meet me after Route 29.\n"
+	.string "I want to see how your KANTO team\n"
+	.string "handles Johto's first quiet road.$"
+
+NewBarkTown_ElmLab_Frlg_Text_Aide::
+	.string "Elm's aide updated your checklist:\p"
+	.string "Route 29, Cherrygrove, Route 30,\n"
+	.string "Sprout Tower, then Falkner.\p"
+	.string "WorldLink notifications stay active\n"
+	.string "outside caves and dungeons.$"
