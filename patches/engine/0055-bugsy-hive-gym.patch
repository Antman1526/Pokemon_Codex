diff --git a/data/maps/AzaleaTown_Gym_Frlg/scripts.inc b/data/maps/AzaleaTown_Gym_Frlg/scripts.inc
new file mode 100644
index 0000000000..8715130826
--- /dev/null
+++ b/data/maps/AzaleaTown_Gym_Frlg/scripts.inc
@@ -0,0 +1,81 @@
+AzaleaTown_Gym_Frlg_MapScripts::
+	map_script MAP_SCRIPT_ON_TRANSITION, AzaleaTown_Gym_Frlg_OnTransition
+	.byte 0
+
+AzaleaTown_Gym_Frlg_OnTransition:
+	setflag FLAG_BUGSY_GYM_REACHED
+	end
+
+AzaleaTown_Gym_Frlg_EventScript_KurtApricornReward::
+	setflag FLAG_APRICORN_FIRST_BATCH_RECEIVED
+	msgbox AzaleaTown_Gym_Frlg_Text_KurtApricornReward, MSGBOX_NPC
+	end
+
+AzaleaTown_Gym_Frlg_EventScript_RedBoundary::
+	msgbox AzaleaTown_Gym_Frlg_Text_RedBoundary, MSGBOX_NPC
+	end
+
+AzaleaTown_Gym_Frlg_EventScript_BugsyBattleScene::
+	setflag FLAG_HIVE_BADGE_REGISTERED
+	msgbox AzaleaTown_Gym_Frlg_Text_BugsyBattleScene, MSGBOX_NPC
+	end
+
+AzaleaTown_Gym_Frlg_EventScript_SilverIlexTrace::
+	msgbox AzaleaTown_Gym_Frlg_Text_SilverIlexTrace, MSGBOX_NPC
+	end
+
+AzaleaTown_Gym_Frlg_EventScript_IlexNext::
+	msgbox AzaleaTown_Gym_Frlg_Text_IlexNext, MSGBOX_NPC
+	end
+
+AzaleaTown_Gym_Frlg_EventScript_GymStatue::
+	msgbox AzaleaTown_Gym_Frlg_Text_GymStatue, MSGBOX_SIGN
+	end
+
+AzaleaTown_Gym_Frlg_Text_KurtApricornReward::
+	.string "KURT: First batch only,\n"
+	.string "Antman.\p"
+	.string "Apricorn craft is not a shop\n"
+	.string "counter. It is trust shaped\n"
+	.string "into a tool.\p"
+	.string "Take these. We will build the\n"
+	.string "full system when Johto is not\n"
+	.string "bleeding from the Well.$"
+
+AzaleaTown_Gym_Frlg_Text_RedBoundary::
+	.string "RED: I am right here.\p"
+	.string "I will train with you after,\n"
+	.string "talk through teams, whatever\n"
+	.string "you need.\p"
+	.string "But this badge is yours.\n"
+	.string "No companion help in Gyms.$"
+
+AzaleaTown_Gym_Frlg_Text_BugsyBattleScene::
+	.string "BUGSY: A swarm is not chaos.\p"
+	.string "Rocket used fear like a bad\n"
+	.string "swarm--small moves, one ugly\n"
+	.string "purpose.\p"
+	.string "A good swarm protects what it\n"
+	.string "moves around.\p"
+	.string "Your rhythm held. HIVE BADGE registered.$"
+
+AzaleaTown_Gym_Frlg_Text_SilverIlexTrace::
+	.string "SILVER TRACE: Ilex side.\p"
+	.string "No battle. Not yet.\p"
+	.string "He saw you protect Slowpoke,\n"
+	.string "then earn a badge without Red.\p"
+	.string "That bothers him more than\n"
+	.string "losing would.$"
+
+AzaleaTown_Gym_Frlg_Text_IlexNext::
+	.string "WorldLink: Ilex Forest next.\p"
+	.string "Rematch Board tier 1 live.\n"
+	.string "Field Tool static detected\n"
+	.string "under the old trees.\p"
+	.string "Hoenn remains locked.$"
+
+AzaleaTown_Gym_Frlg_Text_GymStatue::
+	.string "AZALEA POKEMON GYM\p"
+	.string "LEADER: BUGSY\p"
+	.string "WINNING TRAINERS:\n"
+	.string "{PLAYER}$"
