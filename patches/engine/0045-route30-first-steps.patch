diff --git a/data/maps/Route30_Frlg/scripts.inc b/data/maps/Route30_Frlg/scripts.inc
new file mode 100644
index 0000000000..6ef3af9a1e
--- /dev/null
+++ b/data/maps/Route30_Frlg/scripts.inc
@@ -0,0 +1,84 @@
+Route30_Frlg_MapScripts::
+	map_script MAP_SCRIPT_ON_TRANSITION, Route30_Frlg_OnTransition
+	.byte 0
+
+Route30_Frlg_OnTransition:
+	setflag FLAG_ROUTE30_FIRST_STEPS_REACHED
+	end
+
+Route30_Frlg_EventScript_LyraRoadSupport::
+	msgbox Route30_Frlg_Text_LyraRoadSupport, MSGBOX_NPC
+	end
+
+Route30_Frlg_EventScript_RedWorldLinkCall::
+	msgbox Route30_Frlg_Text_RedWorldLinkCall, MSGBOX_NPC
+	end
+
+Route30_Frlg_EventScript_TrainerRoadPressure::
+	msgbox Route30_Frlg_Text_TrainerRoadPressure, MSGBOX_NPC
+	end
+
+Route30_Frlg_EventScript_GoldDustScout::
+	msgbox Route30_Frlg_Text_GoldDustScout, MSGBOX_NPC
+	end
+
+Route30_Frlg_EventScript_MoonlightPilgrim::
+	msgbox Route30_Frlg_Text_MoonlightPilgrim, MSGBOX_NPC
+	end
+
+Route30_Frlg_EventScript_MrPokemonObjective::
+	msgbox Route30_Frlg_Text_MrPokemonObjective, MSGBOX_NPC
+	end
+
+Route30_Frlg_EventScript_RouteSign::
+	msgbox Route30_Frlg_Text_RouteSign, MSGBOX_SIGN
+	end
+
+Route30_Frlg_Text_LyraRoadSupport::
+	.string "LYRA: This is Route 30.\p"
+	.string "It's Johto's first trainer road,\n"
+	.string "but don't let that rush you.\p"
+	.string "Read people, grass, and rumors.\n"
+	.string "That's how this region talks.$"
+
+Route30_Frlg_Text_RedWorldLinkCall::
+	.string "RED: WorldLink check-in.\p"
+	.string "I stayed behind to compare\n"
+	.string "Cherrygrove guide records.\p"
+	.string "Trust LYRA on this road.\n"
+	.string "Silver battle waits for a place\n"
+	.string "that means something.$"
+
+Route30_Frlg_Text_TrainerRoadPressure::
+	.string "A young trainer watches the path.\p"
+	.string "Route 30 is the first trainer road\n"
+	.string "where Johto tests patience.\p"
+	.string "Winning matters.\n"
+	.string "Knowing when to pause matters too.$"
+
+Route30_Frlg_Text_GoldDustScout::
+	.string "The man folds a gold-edged note.\p"
+	.string "Gold Dust doesn't buy POKEMON.\n"
+	.string "We buy proof of rare history.\p"
+	.string "SPROUT TOWER has records older\n"
+	.string "than badges.$"
+
+Route30_Frlg_Text_MoonlightPilgrim::
+	.string "MOONLIGHT PILGRIM: Bells dream\n"
+	.string "when nobody listens.\p"
+	.string "SPROUT TOWER is whispering in\n"
+	.string "the wrong hour.\p"
+	.string "Do not confuse silence with peace.$"
+
+Route30_Frlg_Text_MrPokemonObjective::
+	.string "Mr. Pokemon sent word from the\n"
+	.string "house ahead.\p"
+	.string "He has an egg, a visitor, and a\n"
+	.string "tower record that should not exist.\p"
+	.string "WorldLink: Mr. Pokemon next.$"
+
+Route30_Frlg_Text_RouteSign::
+	.string "ROUTE 30\p"
+	.string "CHERRYGROVE CITY - MR. POKEMON'S\n"
+	.string "HOUSE\p"
+	.string "No Hoenn route registered.$"
