diff --git a/data/maps/UnionCave_1F_Frlg/scripts.inc b/data/maps/UnionCave_1F_Frlg/scripts.inc
new file mode 100644
index 0000000000..9dbe14af16
--- /dev/null
+++ b/data/maps/UnionCave_1F_Frlg/scripts.inc
@@ -0,0 +1,76 @@
+UnionCave_1F_Frlg_MapScripts::
+	map_script MAP_SCRIPT_ON_TRANSITION, UnionCave_1F_Frlg_OnTransition
+	.byte 0
+
+UnionCave_1F_Frlg_OnTransition:
+	setflag FLAG_UNION_CAVE_FIRST_ENTRY_REACHED
+	end
+
+UnionCave_1F_Frlg_EventScript_LyraEntry::
+	msgbox UnionCave_1F_Frlg_Text_LyraEntry, MSGBOX_NPC
+	end
+
+UnionCave_1F_Frlg_EventScript_RocketGoldDustClash::
+	msgbox UnionCave_1F_Frlg_Text_RocketGoldDustClash, MSGBOX_NPC
+	end
+
+UnionCave_1F_Frlg_EventScript_RedEmergency::
+	setflag FLAG_UNION_CAVE_RED_EMERGENCY_REACHED
+	msgbox UnionCave_1F_Frlg_Text_RedEmergency, MSGBOX_NPC
+	end
+
+UnionCave_1F_Frlg_EventScript_CaveChecklist::
+	setflag FLAG_UNION_CAVE_FIELD_CHECKLIST_REVIEWED
+	msgbox UnionCave_1F_Frlg_Text_CaveChecklist, MSGBOX_NPC
+	end
+
+UnionCave_1F_Frlg_EventScript_SilverExitTrace::
+	msgbox UnionCave_1F_Frlg_Text_SilverExitTrace, MSGBOX_NPC
+	end
+
+UnionCave_1F_Frlg_EventScript_AzaleaExitLock::
+	msgbox UnionCave_1F_Frlg_Text_AzaleaExitLock, MSGBOX_SIGN
+	end
+
+UnionCave_1F_Frlg_Text_LyraEntry::
+	.string "LYRA: Union Cave is where\n"
+	.string "Johto stops whispering.\p"
+	.string "Routes up top can look peaceful.\n"
+	.string "Underground, people argue over\n"
+	.string "who gets to control the path.$"
+
+UnionCave_1F_Frlg_Text_RocketGoldDustClash::
+	.string "ROCKET: This tunnel is still\n"
+	.string "useful, no matter whose logo\n"
+	.string "is on the crate.\p"
+	.string "GOLD DUST: Ownership beats\n"
+	.string "muscle. We can buy the road\n"
+	.string "you are crawling through.$"
+
+UnionCave_1F_Frlg_Text_RedEmergency::
+	.string "RED: I heard the WorldLink\n"
+	.string "signal crack from Violet.\p"
+	.string "I am here if the cave turns,\n"
+	.string "but you still choose the pace.\p"
+	.string "Tag me in only when it matters.$"
+
+UnionCave_1F_Frlg_Text_CaveChecklist::
+	.string "CAVE CHECKLIST: Union Cave.\p"
+	.string "Pack Repels if you want clean\n"
+	.string "movement. Keep an Escape Rope.\p"
+	.string "Habitat hints: ZUBAT swarms,\n"
+	.string "ONIX tunnels, waterline Pokemon\n"
+	.string "more active after dark.$"
+
+UnionCave_1F_Frlg_Text_SilverExitTrace::
+	.string "SILVER TRACE: Exit side.\p"
+	.string "No battle. No speech.\p"
+	.string "His signal points toward Azalea\n"
+	.string "and the old well.$"
+
+UnionCave_1F_Frlg_Text_AzaleaExitLock::
+	.string "WorldLink: Azalea next.\p"
+	.string "Kurt's town signal is unstable.\n"
+	.string "Rocket and Gold Dust are both\n"
+	.string "moving ahead.\p"
+	.string "Hoenn remains locked.$"
