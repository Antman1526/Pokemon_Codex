diff --git a/data/maps/SproutTower_1F_Frlg/scripts.inc b/data/maps/SproutTower_1F_Frlg/scripts.inc
new file mode 100644
index 0000000000..0642dc1908
--- /dev/null
+++ b/data/maps/SproutTower_1F_Frlg/scripts.inc
@@ -0,0 +1,67 @@
+SproutTower_1F_Frlg_MapScripts::
+	map_script MAP_SCRIPT_ON_TRANSITION, SproutTower_1F_Frlg_OnTransition
+	.byte 0
+
+SproutTower_1F_Frlg_OnTransition:
+	setflag FLAG_SPROUT_TOWER_FIRST_FLOOR_REACHED
+	end
+
+SproutTower_1F_Frlg_EventScript_SilverFirstFloor::
+	msgbox SproutTower_1F_Frlg_Text_SilverFirstFloor, MSGBOX_NPC
+	end
+
+SproutTower_1F_Frlg_EventScript_MoonlightBellInk::
+	msgbox SproutTower_1F_Frlg_Text_MoonlightBellInk, MSGBOX_NPC
+	end
+
+SproutTower_1F_Frlg_EventScript_GoldDustArchivePressure::
+	msgbox SproutTower_1F_Frlg_Text_GoldDustArchivePressure, MSGBOX_NPC
+	end
+
+SproutTower_1F_Frlg_EventScript_ElderUpperFloor::
+	msgbox SproutTower_1F_Frlg_Text_ElderUpperFloor, MSGBOX_NPC
+	end
+
+SproutTower_1F_Frlg_EventScript_RedStaysOutsideNote::
+	msgbox SproutTower_1F_Frlg_Text_RedStaysOutsideNote, MSGBOX_NPC
+	end
+
+SproutTower_1F_Frlg_EventScript_TowerSign::
+	msgbox SproutTower_1F_Frlg_Text_TowerSign, MSGBOX_SIGN
+	end
+
+SproutTower_1F_Frlg_Text_SilverFirstFloor::
+	.string "SILVER: Not here.\p"
+	.string "I am not giving you our first\n"
+	.string "battle beside an entrance.\p"
+	.string "Climb. If this tower remembers\n"
+	.string "weakness, it can watch us.$"
+
+SproutTower_1F_Frlg_Text_MoonlightBellInk::
+	.string "MOONLIGHT PILGRIM: The bells are written over.\p"
+	.string "Ink moves where prayer should be.\p"
+	.string "The tower dreams in edits now,\n"
+	.string "and the egg hears every mark.$"
+
+SproutTower_1F_Frlg_Text_GoldDustArchivePressure::
+	.string "GOLD DUST BUYER: Archives are cleaner\n"
+	.string "than memory.\p"
+	.string "A signed record can own a myth\n"
+	.string "long after witnesses disagree.$"
+
+SproutTower_1F_Frlg_Text_ElderUpperFloor::
+	.string "ELDER: Climb higher.\p"
+	.string "This floor hears the argument.\n"
+	.string "The upper floor keeps the lesson.\p"
+	.string "WorldLink: Sprout Tower upper floor next.$"
+
+SproutTower_1F_Frlg_Text_RedStaysOutsideNote::
+	.string "RED: I am staying outside.\p"
+	.string "Not because I am leaving you.\n"
+	.string "Because Johto is asking you.\p"
+	.string "I will be here when you return.$"
+
+SproutTower_1F_Frlg_Text_TowerSign::
+	.string "SPROUT TOWER 1F\p"
+	.string "Red stays outside.\n"
+	.string "Hoenn remains locked.$"
