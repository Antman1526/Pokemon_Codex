diff --git a/data/maps/NewBarkTown_Frlg/scripts.inc b/data/maps/NewBarkTown_Frlg/scripts.inc
new file mode 100644
index 0000000000..bc737b6c13
--- /dev/null
+++ b/data/maps/NewBarkTown_Frlg/scripts.inc
@@ -0,0 +1,59 @@
+NewBarkTown_Frlg_MapScripts::
+	map_script MAP_SCRIPT_ON_TRANSITION, NewBarkTown_Frlg_OnTransition
+	.byte 0
+
+NewBarkTown_Frlg_OnTransition:
+	setflag FLAG_NEW_BARK_ARRIVAL_REACHED
+	end
+
+NewBarkTown_Frlg_EventScript_RedArrival::
+	msgbox NewBarkTown_Frlg_Text_RedArrival, MSGBOX_NPC
+	end
+
+NewBarkTown_Frlg_EventScript_LyraArrival::
+	msgbox NewBarkTown_Frlg_Text_LyraArrival, MSGBOX_NPC
+	end
+
+NewBarkTown_Frlg_EventScript_ElmSignal::
+	msgbox NewBarkTown_Frlg_Text_ElmSignal, MSGBOX_NPC
+	end
+
+NewBarkTown_Frlg_EventScript_TownSign::
+	msgbox NewBarkTown_Frlg_Text_TownSign, MSGBOX_SIGN
+	end
+
+NewBarkTown_Frlg_EventScript_WorldLinkSign::
+	msgbox NewBarkTown_Frlg_Text_WorldLinkSign, MSGBOX_SIGN
+	end
+
+NewBarkTown_Frlg_Text_RedArrival::
+	.string "RED: We made it, Antman.\p"
+	.string "Johto feels quieter than KANTO,\n"
+	.string "but not smaller.\p"
+	.string "I'll stay close on the early road.\n"
+	.string "Gyms are yours. Trouble is ours.$"
+
+NewBarkTown_Frlg_Text_LyraArrival::
+	.string "LYRA: Welcome to Johto, Antman!\p"
+	.string "I watched your KANTO feed, but this\n"
+	.string "is better than a profile alert.\p"
+	.string "Silver profile moved toward Cherrygrove\n"
+	.string "before I could get a clean read.\p"
+	.string "Let's not call him an enemy yet.$"
+
+NewBarkTown_Frlg_Text_ElmSignal::
+	.string "ELM: New Bark Lab has your clearance.\p"
+	.string "WorldLink: Johto active.\n"
+	.string "First objective: reach my lab.\p"
+	.string "Hoenn remains locked until Johto's\n"
+	.string "tower and legendary signals settle.$"
+
+NewBarkTown_Frlg_Text_TownSign::
+	.string "NEW BARK TOWN\p"
+	.string "The town where Johto's wind begins.$"
+
+NewBarkTown_Frlg_Text_WorldLinkSign::
+	.string "WorldLink Gate Status:\p"
+	.string "KANTO departure complete.\n"
+	.string "JOHTO active.\p"
+	.string "Hoenn remains locked.$"
