diff --git a/data/maps/VioletCity_Frlg/scripts.inc b/data/maps/VioletCity_Frlg/scripts.inc
new file mode 100644
index 0000000000..fb3b7760a4
--- /dev/null
+++ b/data/maps/VioletCity_Frlg/scripts.inc
@@ -0,0 +1,81 @@
+VioletCity_Frlg_MapScripts::
+	map_script MAP_SCRIPT_ON_TRANSITION, VioletCity_Frlg_OnTransition
+	.byte 0
+
+VioletCity_Frlg_OnTransition:
+	setflag FLAG_VIOLET_CITY_FIRST_ARRIVAL_REACHED
+	end
+
+VioletCity_Frlg_EventScript_RedVioletReturn::
+	msgbox VioletCity_Frlg_Text_RedVioletReturn, MSGBOX_NPC
+	end
+
+VioletCity_Frlg_EventScript_LyraLocalGuide::
+	msgbox VioletCity_Frlg_Text_LyraLocalGuide, MSGBOX_NPC
+	end
+
+VioletCity_Frlg_EventScript_FalknerTowerGate::
+	msgbox VioletCity_Frlg_Text_FalknerTowerGate, MSGBOX_NPC
+	end
+
+VioletCity_Frlg_EventScript_SilverTowerWarning::
+	msgbox VioletCity_Frlg_Text_SilverTowerWarning, MSGBOX_NPC
+	end
+
+VioletCity_Frlg_EventScript_MoonlightBellRecord::
+	msgbox VioletCity_Frlg_Text_MoonlightBellRecord, MSGBOX_NPC
+	end
+
+VioletCity_Frlg_EventScript_GoldDustArchiveBuyer::
+	msgbox VioletCity_Frlg_Text_GoldDustArchiveBuyer, MSGBOX_NPC
+	end
+
+VioletCity_Frlg_EventScript_CitySign::
+	msgbox VioletCity_Frlg_Text_CitySign, MSGBOX_SIGN
+	end
+
+VioletCity_Frlg_Text_RedVioletReturn::
+	.string "RED: I caught up.\p"
+	.string "Cherrygrove's guide records match\n"
+	.string "the Nexus Egg rhythm.\p"
+	.string "This city is quiet, but it is not\n"
+	.string "simple. I am with you.$"
+
+VioletCity_Frlg_Text_LyraLocalGuide::
+	.string "LYRA: Violet City lives by bells,\n"
+	.string "school, and sky discipline.\p"
+	.string "Around here, you do not just walk\n"
+	.string "into a Gym and demand a badge.\p"
+	.string "You listen first.$"
+
+VioletCity_Frlg_Text_FalknerTowerGate::
+	.string "FALKNER: Sprout Tower before Falkner.\p"
+	.string "That is not a delay. It is respect.\p"
+	.string "If the tower records were edited,\n"
+	.string "my Gym cannot certify the wind yet.$"
+
+VioletCity_Frlg_Text_SilverTowerWarning::
+	.string "SILVER: The tower first.\p"
+	.string "I am not wasting our first battle\n"
+	.string "on a road or a crowd.\p"
+	.string "If Johto remembers weakness there,\n"
+	.string "then that is where I will test you.$"
+
+VioletCity_Frlg_Text_MoonlightBellRecord::
+	.string "MOONLIGHT PILGRIM: Bell records\n"
+	.string "should not dream in ink.\p"
+	.string "Someone wrote over an old silence,\n"
+	.string "and now the tower hears it.$"
+
+VioletCity_Frlg_Text_GoldDustArchiveBuyer::
+	.string "GOLD DUST BUYER: Tower archives\n"
+	.string "prove lineage, ownership, and myth.\p"
+	.string "We only buy what history is ready\n"
+	.string "to sell.$"
+
+VioletCity_Frlg_Text_CitySign::
+	.string "VIOLET CITY\p"
+	.string "The old tower watches the first\n"
+	.string "Johto badge.\p"
+	.string "WorldLink: Sprout Tower next.\n"
+	.string "Hoenn remains locked.$"
