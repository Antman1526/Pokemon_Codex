diff --git a/data/maps/VioletCity_Gym_Frlg/scripts.inc b/data/maps/VioletCity_Gym_Frlg/scripts.inc
new file mode 100644
index 0000000000..7de72bc167
--- /dev/null
+++ b/data/maps/VioletCity_Gym_Frlg/scripts.inc
@@ -0,0 +1,73 @@
+VioletCity_Gym_Frlg_MapScripts::
+	map_script MAP_SCRIPT_ON_TRANSITION, VioletCity_Gym_Frlg_OnTransition
+	.byte 0
+
+VioletCity_Gym_Frlg_OnTransition:
+	setflag FLAG_FALKNER_GYM_REACHED
+	end
+
+VioletCity_Gym_Frlg_EventScript_RedAfterTower::
+	msgbox VioletCity_Gym_Frlg_Text_RedAfterTower, MSGBOX_NPC
+	end
+
+VioletCity_Gym_Frlg_EventScript_AvaBellAnalysis::
+	msgbox VioletCity_Gym_Frlg_Text_AvaBellAnalysis, MSGBOX_NPC
+	end
+
+VioletCity_Gym_Frlg_EventScript_FalknerBattleScene::
+	setflag FLAG_ZEPHYR_BADGE_REGISTERED
+	msgbox VioletCity_Gym_Frlg_Text_FalknerBattleScene, MSGBOX_NPC
+	end
+
+VioletCity_Gym_Frlg_EventScript_FieldChecklist::
+	msgbox VioletCity_Gym_Frlg_Text_FieldChecklist, MSGBOX_NPC
+	end
+
+VioletCity_Gym_Frlg_EventScript_Route32Next::
+	msgbox VioletCity_Gym_Frlg_Text_Route32Next, MSGBOX_NPC
+	end
+
+VioletCity_Gym_Frlg_EventScript_GymStatue::
+	msgbox VioletCity_Gym_Frlg_Text_GymStatue, MSGBOX_SIGN
+	end
+
+VioletCity_Gym_Frlg_Text_RedAfterTower::
+	.string "RED: You carried the tower.\p"
+	.string "I am proud of that.\n"
+	.string "Not because you won alone.\p"
+	.string "Because you listened before\n"
+	.string "you pushed forward.$"
+
+VioletCity_Gym_Frlg_Text_AvaBellAnalysis::
+	.string "AVA: Bell analysis complete.\p"
+	.string "MOONLIGHT changed the record\n"
+	.string "like it was a route signal.\p"
+	.string "After this badge, I am turning\n"
+	.string "on your Field Checklist page.$"
+
+VioletCity_Gym_Frlg_Text_FalknerBattleScene::
+	.string "FALKNER: Flying-type control lesson.\p"
+	.string "Wind wins by reading pressure,\n"
+	.string "not by pretending it is stone.\p"
+	.string "Your rhythm held. ZEPHYR BADGE registered.\p"
+	.string "Let this badge remind you:\n"
+	.string "routes move before enemies do.$"
+
+VioletCity_Gym_Frlg_Text_FieldChecklist::
+	.string "Field Checklist page unlocked.\p"
+	.string "WorldLink will now mark active\n"
+	.string "routes, habitat notes, and safe\l"
+	.string "next steps for Johto.$"
+
+VioletCity_Gym_Frlg_Text_Route32Next::
+	.string "SILVER left without a word.\p"
+	.string "That is worse than bragging.\n"
+	.string "He is already reading Route 32.\p"
+	.string "WorldLink: Route 32 next.\n"
+	.string "Hoenn remains locked.$"
+
+VioletCity_Gym_Frlg_Text_GymStatue::
+	.string "VIOLET POKEMON GYM\p"
+	.string "LEADER: FALKNER\p"
+	.string "WINNING TRAINERS:\n"
+	.string "{PLAYER}$"
