diff --git a/data/maps/IlexForest_Frlg/scripts.inc b/data/maps/IlexForest_Frlg/scripts.inc
new file mode 100644
index 0000000000..4ab511d504
--- /dev/null
+++ b/data/maps/IlexForest_Frlg/scripts.inc
@@ -0,0 +1,97 @@
+IlexForest_Frlg_MapScripts::
+	map_script MAP_SCRIPT_ON_TRANSITION, IlexForest_Frlg_OnTransition
+	.byte 0
+
+IlexForest_Frlg_OnTransition:
+	setflag FLAG_ILEX_FOREST_FIRST_ENTRY_REACHED
+	end
+
+IlexForest_Frlg_EventScript_RedEdgeSupport::
+	msgbox IlexForest_Frlg_Text_RedEdgeSupport, MSGBOX_NPC
+	end
+
+IlexForest_Frlg_EventScript_LyraFarfetchdMemory::
+	msgbox IlexForest_Frlg_Text_LyraFarfetchdMemory, MSGBOX_NPC
+	end
+
+IlexForest_Frlg_EventScript_FieldToolStatic::
+	setflag FLAG_ILEX_FIELD_TOOL_STATIC_REACHED
+	msgbox IlexForest_Frlg_Text_FieldToolStatic, MSGBOX_NPC
+	end
+
+IlexForest_Frlg_EventScript_MoonlightShrine::
+	msgbox IlexForest_Frlg_Text_MoonlightShrine, MSGBOX_NPC
+	end
+
+IlexForest_Frlg_EventScript_SilverSecretAssist::
+	setflag FLAG_ILEX_SILVER_SECRET_ASSIST_REACHED
+	msgbox IlexForest_Frlg_Text_SilverSecretAssist, MSGBOX_NPC
+	end
+
+IlexForest_Frlg_EventScript_CelebiWhisper::
+	msgbox IlexForest_Frlg_Text_CelebiWhisper, MSGBOX_NPC
+	end
+
+IlexForest_Frlg_EventScript_GoldenrodNext::
+	msgbox IlexForest_Frlg_Text_GoldenrodNext, MSGBOX_NPC
+	end
+
+IlexForest_Frlg_EventScript_ForestSign::
+	msgbox IlexForest_Frlg_Text_ForestSign, MSGBOX_SIGN
+	end
+
+IlexForest_Frlg_Text_RedEdgeSupport::
+	.string "RED: Old forests do not like\n"
+	.string "orders.\p"
+	.string "They like quiet, patience,\n"
+	.string "and people who notice when a\n"
+	.string "path is asking a question.$"
+
+IlexForest_Frlg_Text_LyraFarfetchdMemory::
+	.string "LYRA: This is the old Farfetch'd\n"
+	.string "route memory.\p"
+	.string "Johto used to teach CUT here.\n"
+	.string "Now your Field Tools are\n"
+	.string "hearing the same lesson wrong.$"
+
+IlexForest_Frlg_Text_FieldToolStatic::
+	.string "FIELD TOOL STATIC detected.\p"
+	.string "Trail Cutter responds, then\n"
+	.string "folds back like the forest is\n"
+	.string "remembering an older command.\p"
+	.string "Prototype logged. Full Field\n"
+	.string "Tool expansion waits for Goldenrod.$"
+
+IlexForest_Frlg_Text_MoonlightShrine::
+	.string "MOONLIGHT: Memory is a path.\p"
+	.string "If a shrine remembers enough,\n"
+	.string "the road can be tuned before\n"
+	.string "any trainer steps on it.\p"
+	.string "Rocket steals bodies. Gold Dust\n"
+	.string "prices fear. We edit return.$"
+
+IlexForest_Frlg_Text_SilverSecretAssist::
+	.string "SILVER TRACE: Cut branch.\p"
+	.string "No speech. No battle.\p"
+	.string "Someone cleared this before\n"
+	.string "you reached it, then left like\n"
+	.string "helping was an accident.$"
+
+IlexForest_Frlg_Text_CelebiWhisper::
+	.string "CELEBI SHRINE: Time remembers\n"
+	.string "a trainer from Pallet.\p"
+	.string "Your lead Pokemon reacts, but\n"
+	.string "Following Pokemon remains locked\n"
+	.string "until Goldenrod can stabilize it.$"
+
+IlexForest_Frlg_Text_GoldenrodNext::
+	.string "WorldLink: Goldenrod City next.\p"
+	.string "Full Field Tool support,\n"
+	.string "Following Pokemon tease, and\n"
+	.string "Radio Tower pressure logged.\p"
+	.string "Hoenn remains locked.$"
+
+IlexForest_Frlg_Text_ForestSign::
+	.string "ILEX FOREST\p"
+	.string "A quiet shrine, an old CUT\n"
+	.string "lesson, and paths that remember.$"
