+++ b/data/maps/CherrygroveCity_Frlg/scripts.inc
@@ -0,0 +1,87 @@
+CherrygroveCity_Frlg_MapScripts::
+	map_script MAP_SCRIPT_ON_TRANSITION, CherrygroveCity_Frlg_OnTransition
+	.byte 0
+
+CherrygroveCity_Frlg_OnTransition:
+	setflag FLAG_CHERRYGROVE_FIRST_ARRIVAL_REACHED
+	end
+
+CherrygroveCity_Frlg_EventScript_RedCheckIn::
+	msgbox CherrygroveCity_Frlg_Text_RedCheckIn, MSGBOX_NPC
+	end
+
+CherrygroveCity_Frlg_EventScript_LyraCheckpoint::
+	msgbox CherrygroveCity_Frlg_Text_LyraCheckpoint, MSGBOX_NPC
+	end
+
+CherrygroveCity_Frlg_EventScript_GuideWatchNetwork::
+	msgbox CherrygroveCity_Frlg_Text_GuideWatchNetwork, MSGBOX_NPC
+	end
+
+CherrygroveCity_Frlg_EventScript_SilverWarning::
+	msgbox CherrygroveCity_Frlg_Text_SilverWarning, MSGBOX_NPC
+	end
+
+CherrygroveCity_Frlg_EventScript_GoldDustReceipt::
+	msgbox CherrygroveCity_Frlg_Text_GoldDustReceipt, MSGBOX_NPC
+	end
+
+CherrygroveCity_Frlg_EventScript_CitySign::
+	msgbox CherrygroveCity_Frlg_Text_CitySign, MSGBOX_SIGN
+	end
+
+CherrygroveCity_Frlg_EventScript_Route30Sign::
+	msgbox CherrygroveCity_Frlg_Text_Route30Sign, MSGBOX_SIGN
+	end
+
+CherrygroveCity_Frlg_Text_RedCheckIn::
+	.string "RED: Cherrygrove feels quiet,\n"
+	.string "but not empty.\p"
+	.string "Rest here, talk to people, and let\n"
+	.string "Johto show its pace.\p"
+	.string "I'll stay close.\n"
+	.string "This is still your road.$"
+
+CherrygroveCity_Frlg_Text_LyraCheckpoint::
+	.string "LYRA: This is where Johto starts\n"
+	.string "watching back.\p"
+	.string "Not in a scary way.\n"
+	.string "Mostly.\p"
+	.string "Our towns keep stories like KANTO\n"
+	.string "keeps badges.$"
+
+CherrygroveCity_Frlg_Text_GuideWatchNetwork::
+	.string "GUIDE: New face from NEW BARK!\p"
+	.string "Take the Map Card.\n"
+	.string "It marks safe roads and odd signals.\p"
+	.string "Take this Apricorn Case note too.\n"
+	.string "Kurt will know what to do later.\p"
+	.string "The guide network helps travelers,\n"
+	.string "but it also remembers unusual routes.$"
+
+CherrygroveCity_Frlg_Text_SilverWarning::
+	.string "SILVER: You keep following the map.\p"
+	.string "Maps are made by people who want\n"
+	.string "you to walk where they can see you.\p"
+	.string "Tell RED that shadows move faster\n"
+	.string "when nobody names them.$"
+
+CherrygroveCity_Frlg_Text_GoldDustReceipt::
+	.string "A folded receipt is tucked under\n"
+	.string "the travel board.\p"
+	.string "Gold Dust purchase inquiry:\n"
+	.string "old tower records, bell patterns,\n"
+	.string "rare lineage papers.\p"
+	.string "Delivery held until SPROUT TOWER\n"
+	.string "custodian confirms the buyer.$"
+
+CherrygroveCity_Frlg_Text_CitySign::
+	.string "CHERRYGROVE CITY\p"
+	.string "The town where old roads learn\n"
+	.string "new names.\p"
+	.string "No Hoenn route registered.$"
+
+CherrygroveCity_Frlg_Text_Route30Sign::
+	.string "WorldLink: Route 30 next.\p"
+	.string "Mr. Pokemon's road, trainer reports,\n"
+	.string "and Sprout Tower records ahead.$"
