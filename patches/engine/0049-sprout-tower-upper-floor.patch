@@ -0,0 +1,70 @@
+SproutTower_Upper_Frlg_MapScripts::
+	map_script MAP_SCRIPT_ON_TRANSITION, SproutTower_Upper_Frlg_OnTransition
+	.byte 0
+
+SproutTower_Upper_Frlg_OnTransition:
+	setflag FLAG_SPROUT_TOWER_UPPER_FLOOR_REACHED
+	end
+
+SproutTower_Upper_Frlg_EventScript_ElderLesson::
+	msgbox SproutTower_Upper_Frlg_Text_ElderLesson, MSGBOX_NPC
+	end
+
+SproutTower_Upper_Frlg_EventScript_SilverFirstBattle::
+	msgbox SproutTower_Upper_Frlg_Text_SilverFirstBattle, MSGBOX_NPC
+	end
+
+SproutTower_Upper_Frlg_EventScript_CursedBellRecord::
+	msgbox SproutTower_Upper_Frlg_Text_CursedBellRecord, MSGBOX_NPC
+	end
+
+SproutTower_Upper_Frlg_EventScript_GoldDustReceipt::
+	msgbox SproutTower_Upper_Frlg_Text_GoldDustReceipt, MSGBOX_NPC
+	end
+
+SproutTower_Upper_Frlg_EventScript_FalknerGymUnlock::
+	msgbox SproutTower_Upper_Frlg_Text_FalknerGymUnlock, MSGBOX_NPC
+	end
+
+SproutTower_Upper_Frlg_EventScript_UpperFloorSign::
+	msgbox SproutTower_Upper_Frlg_Text_UpperFloorSign, MSGBOX_SIGN
+	end
+
+SproutTower_Upper_Frlg_Text_ElderLesson::
+	.string "ELDER: Flexibility before force.\p"
+	.string "A tower that will not bend\n"
+	.string "falls before the storm ends.\p"
+	.string "Your journey crossed Kanto by\n"
+	.string "strength. Johto asks for rhythm.$"
+
+SproutTower_Upper_Frlg_Text_SilverFirstBattle::
+	.string "SILVER: Now we battle.\p"
+	.string "If bending is the lesson, then\n"
+	.string "show me it is not just fear.\p"
+	.string "I will not let old men, rivals,\n"
+	.string "or a famous friend carry you.$"
+
+SproutTower_Upper_Frlg_Text_CursedBellRecord::
+	.string "MOONLIGHT RECORD: Cursed bell record.\p"
+	.string "The ink repeats the same note,\n"
+	.string "but the meaning keeps changing.\p"
+	.string "Ava should see this. It is a\n"
+	.string "route signal, not a relic.$"
+
+SproutTower_Upper_Frlg_Text_GoldDustReceipt::
+	.string "GOLD DUST RECEIPT: Archive purchase failed.\p"
+	.string "Reason: Elder refused transfer.\p"
+	.string "Fallback: seek cleaner market\n"
+	.string "channels west of Violet.$"
+
+SproutTower_Upper_Frlg_Text_FalknerGymUnlock::
+	.string "FALKNER: Zephyr Gym unlocked.\p"
+	.string "The Elder says you listened\n"
+	.string "before you pushed forward.\p"
+	.string "WorldLink: Falkner Gym next.\n"
+	.string "Hoenn remains locked.$"
+
+SproutTower_Upper_Frlg_Text_UpperFloorSign::
+	.string "SPROUT TOWER UPPER FLOOR\p"
+	.string "Field Checklist page teased.\n"
+	.string "Falkner waits below the wind.$"
