diff --git a/data/maps/SlowpokeWell_B1F_Frlg/scripts.inc b/data/maps/SlowpokeWell_B1F_Frlg/scripts.inc
new file mode 100644
index 0000000000..6cedf5f8a9
--- /dev/null
+++ b/data/maps/SlowpokeWell_B1F_Frlg/scripts.inc
@@ -0,0 +1,95 @@
+SlowpokeWell_B1F_Frlg_MapScripts::
+	map_script MAP_SCRIPT_ON_TRANSITION, SlowpokeWell_B1F_Frlg_OnTransition
+	.byte 0
+
+SlowpokeWell_B1F_Frlg_OnTransition:
+	setflag FLAG_SLOWPOKE_WELL_FIRST_ENTRY_REACHED
+	end
+
+SlowpokeWell_B1F_Frlg_EventScript_KurtPartner::
+	setflag FLAG_SLOWPOKE_WELL_KURT_PARTNER_REACHED
+	msgbox SlowpokeWell_B1F_Frlg_Text_KurtPartner, MSGBOX_NPC
+	end
+
+SlowpokeWell_B1F_Frlg_EventScript_RocketReturn::
+	msgbox SlowpokeWell_B1F_Frlg_Text_RocketReturn, MSGBOX_NPC
+	end
+
+SlowpokeWell_B1F_Frlg_EventScript_GoldDustEvidence::
+	setflag FLAG_SLOWPOKE_WELL_ROCKET_EVIDENCE_REACHED
+	msgbox SlowpokeWell_B1F_Frlg_Text_GoldDustEvidence, MSGBOX_NPC
+	end
+
+SlowpokeWell_B1F_Frlg_EventScript_SlowpokeRescue::
+	msgbox SlowpokeWell_B1F_Frlg_Text_SlowpokeRescue, MSGBOX_NPC
+	end
+
+SlowpokeWell_B1F_Frlg_EventScript_RedOutsideWatch::
+	msgbox SlowpokeWell_B1F_Frlg_Text_RedOutsideWatch, MSGBOX_NPC
+	end
+
+SlowpokeWell_B1F_Frlg_EventScript_SilverTrace::
+	msgbox SlowpokeWell_B1F_Frlg_Text_SilverTrace, MSGBOX_NPC
+	end
+
+SlowpokeWell_B1F_Frlg_EventScript_BugsyUnlock::
+	msgbox SlowpokeWell_B1F_Frlg_Text_BugsyUnlock, MSGBOX_NPC
+	end
+
+SlowpokeWell_B1F_Frlg_EventScript_WellSign::
+	msgbox SlowpokeWell_B1F_Frlg_Text_WellSign, MSGBOX_SIGN
+	end
+
+SlowpokeWell_B1F_Frlg_Text_KurtPartner::
+	.string "KURT: This is not a market.\p"
+	.string "Slowpoke trusted this town\n"
+	.string "before any of us had badges.\p"
+	.string "Walk with me, Antman. We fix\n"
+	.string "this without turning kindness\n"
+	.string "into a trophy.$"
+
+SlowpokeWell_B1F_Frlg_Text_RocketReturn::
+	.string "ROCKET: The tails are proof\n"
+	.string "that Johto still pays.\p"
+	.string "Kanto broke our sign, not our\n"
+	.string "routes. The Boss would know\n"
+	.string "what to do with this well.$"
+
+SlowpokeWell_B1F_Frlg_Text_GoldDustEvidence::
+	.string "GOLD DUST: Rocket makes\n"
+	.string "excellent evidence.\p"
+	.string "Let them look cruel. We will\n"
+	.string "sell the cleanup, the permits,\n"
+	.string "and the new rules afterward.$"
+
+SlowpokeWell_B1F_Frlg_Text_SlowpokeRescue::
+	.string "SLOWPOKE: ...Yawn...\p"
+	.string "The Slowpoke looks tired,\n"
+	.string "but safe enough to stand.\p"
+	.string "WorldLink logs the rescue.$"
+
+SlowpokeWell_B1F_Frlg_Text_RedOutsideWatch::
+	.string "RED: I am outside.\p"
+	.string "No one leaves through Union\n"
+	.string "Cave without you knowing.\p"
+	.string "Kurt is with you. Listen to\n"
+	.string "him down there.$"
+
+SlowpokeWell_B1F_Frlg_Text_SilverTrace::
+	.string "SILVER TRACE: He saw Rocket\n"
+	.string "stealing strength and stayed\n"
+	.string "angry instead of loud.\p"
+	.string "No battle yet. Not because he\n"
+	.string "is calm.$"
+
+SlowpokeWell_B1F_Frlg_Text_BugsyUnlock::
+	.string "WorldLink: Bugsy Gym next.\p"
+	.string "Azalea emergency stabilizing.\n"
+	.string "Apricorn first-batch reward\n"
+	.string "pending with Kurt.\p"
+	.string "Hoenn remains locked.$"
+
+SlowpokeWell_B1F_Frlg_Text_WellSign::
+	.string "SLOWPOKE WELL\p"
+	.string "Protected town waterway.\n"
+	.string "Do not disturb Slowpoke.$"
