diff --git a/data/maps/MrPokemonsHouse_Frlg/scripts.inc b/data/maps/MrPokemonsHouse_Frlg/scripts.inc
new file mode 100644
index 0000000000..af158700c8
--- /dev/null
+++ b/data/maps/MrPokemonsHouse_Frlg/scripts.inc
@@ -0,0 +1,62 @@
+MrPokemonsHouse_Frlg_MapScripts::
+	map_script MAP_SCRIPT_ON_TRANSITION, MrPokemonsHouse_Frlg_OnTransition
+	.byte 0
+
+MrPokemonsHouse_Frlg_OnTransition:
+	setflag FLAG_MR_POKEMON_HOUSE_FIRST_VISIT_REACHED
+	end
+
+MrPokemonsHouse_Frlg_EventScript_MrPokemonNexusEgg::
+	msgbox MrPokemonsHouse_Frlg_Text_MrPokemonNexusEgg, MSGBOX_NPC
+	end
+
+MrPokemonsHouse_Frlg_EventScript_OakOldStoryNewMap::
+	msgbox MrPokemonsHouse_Frlg_Text_OakOldStoryNewMap, MSGBOX_NPC
+	end
+
+MrPokemonsHouse_Frlg_EventScript_AvaResearchFeed::
+	msgbox MrPokemonsHouse_Frlg_Text_AvaResearchFeed, MSGBOX_NPC
+	end
+
+MrPokemonsHouse_Frlg_EventScript_ElmVioletHandoff::
+	msgbox MrPokemonsHouse_Frlg_Text_ElmVioletHandoff, MSGBOX_NPC
+	end
+
+MrPokemonsHouse_Frlg_EventScript_ResearchConsole::
+	msgbox MrPokemonsHouse_Frlg_Text_ResearchConsole, MSGBOX_SIGN
+	end
+
+MrPokemonsHouse_Frlg_Text_MrPokemonNexusEgg::
+	.string "MR. POKEMON: This is not a normal egg.\p"
+	.string "I found it beside records that\n"
+	.string "should only exist in SPROUT TOWER.\p"
+	.string "Call it the Nexus Egg until ELM\n"
+	.string "proves otherwise.$"
+
+MrPokemonsHouse_Frlg_Text_OakOldStoryNewMap::
+	.string "OAK: The old story is still true,\n"
+	.string "Antman.\p"
+	.string "A trainer comes here, receives an\n"
+	.string "egg, and Johto opens wider.\p"
+	.string "But your map is larger now.\n"
+	.string "Protect the Nexus Egg.$"
+
+MrPokemonsHouse_Frlg_Text_AvaResearchFeed::
+	.string "AVA: Remote feed stable.\p"
+	.string "The shell is giving route data,\n"
+	.string "not just life signs.\p"
+	.string "I am logging this as a living\n"
+	.string "WorldLink signal.$"
+
+MrPokemonsHouse_Frlg_Text_ElmVioletHandoff::
+	.string "ELM: Violet City next.\p"
+	.string "FALKNER can wait until SPROUT\n"
+	.string "TOWER records are checked.\p"
+	.string "WorldLink: Violet City next.\n"
+	.string "Hoenn remains locked.$"
+
+MrPokemonsHouse_Frlg_Text_ResearchConsole::
+	.string "A small console displays egg shell\n"
+	.string "resonance and tower bell timing.\p"
+	.string "One record was edited before\n"
+	.string "Antman entered Johto.$"
