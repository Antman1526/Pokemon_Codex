diff --git a/data/maps/Route29_Frlg/scripts.inc b/data/maps/Route29_Frlg/scripts.inc
new file mode 100644
index 0000000000..8c3492d8c1
--- /dev/null
+++ b/data/maps/Route29_Frlg/scripts.inc
@@ -0,0 +1,58 @@
+Route29_Frlg_MapScripts::
+	map_script MAP_SCRIPT_ON_TRANSITION, Route29_Frlg_OnTransition
+	.byte 0
+
+Route29_Frlg_OnTransition:
+	setflag FLAG_ROUTE29_FIRST_STEPS_REACHED
+	end
+
+Route29_Frlg_EventScript_RedFieldSupport::
+	msgbox Route29_Frlg_Text_RedFieldSupport, MSGBOX_NPC
+	end
+
+Route29_Frlg_EventScript_LyraCherrygroveHandoff::
+	msgbox Route29_Frlg_Text_LyraCherrygroveHandoff, MSGBOX_NPC
+	end
+
+Route29_Frlg_EventScript_SilverShadow::
+	msgbox Route29_Frlg_Text_SilverShadow, MSGBOX_NPC
+	end
+
+Route29_Frlg_EventScript_DayNightSign::
+	msgbox Route29_Frlg_Text_DayNightSign, MSGBOX_NPC
+	end
+
+Route29_Frlg_EventScript_RouteSign::
+	msgbox Route29_Frlg_Text_RouteSign, MSGBOX_SIGN
+	end
+
+Route29_Frlg_Text_RedFieldSupport::
+	.string "RED: This is Johto's first real road,\n"
+	.string "Antman.\p"
+	.string "I'll walk nearby, but I won't steer\n"
+	.string "your team.\p"
+	.string "Johto listens before it pushes.\n"
+	.string "Take your time.$"
+
+Route29_Frlg_Text_LyraCherrygroveHandoff::
+	.string "LYRA: Cherrygrove is close.\p"
+	.string "The guide there knows every shortcut,\n"
+	.string "but he also notices who avoids them.\p"
+	.string "WorldLink: Cherrygrove next.$"
+
+Route29_Frlg_Text_SilverShadow::
+	.string "SILVER: ...\p"
+	.string "You brought KANTO's shadow with you.\p"
+	.string "Good.\n"
+	.string "Then you might survive Johto.$"
+
+Route29_Frlg_Text_DayNightSign::
+	.string "Elm's route note:\p"
+	.string "Route 29 changes between day and night.\p"
+	.string "Some Pokemon only show themselves\n"
+	.string "when the road is quiet.$"
+
+Route29_Frlg_Text_RouteSign::
+	.string "ROUTE 29\p"
+	.string "NEW BARK TOWN - CHERRYGROVE CITY\p"
+	.string "No Hoenn route registered.$"
